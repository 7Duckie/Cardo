# ─── Cardo's own runtime artifacts ────────────────────────────────────
# A developer running cardo against test fixtures will end up with these.
# They contain real-world hashes / logs / reports from local runs and
# shouldn't end up in commits.
.cardo/
test_output/
*.cardo.bak

# Reports cardo writes into the working directory if --report is used
# with an explicit path
cardo_*.html

# Local config overrides
.envrc
.tool-versions
